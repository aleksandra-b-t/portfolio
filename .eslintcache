ount":0,"fixableWarningCount":0,"usedDeprecatedRules":"20"},{"filePath":"32","messages":"33","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"20"},{"filePath":"34","messages":"35","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/Users/aleksandra/Flatiron/projects/portfolio/aleksandra/src/index.js",[],["36","37"],"/Users/aleksandra/Flatiron/projects/portfolio/aleksandra/src/App.js",["38","39","40","41","42"],"/Users/aleksandra/Flatiron/projects/portfolio/aleksandra/src/reportWebVitals.js",[],"/Users/aleksandra/Flatiron/projects/portfolio/aleksandra/src/components/About.js",[],"/Users/aleksandra/Flatiron/projects/portfolio/aleksandra/src/components/Experience.js",["43","44","45"],"import React from 'react';\nimport ff from '../images/ff.jpeg';\nimport fp from '../images/fp.png';\nimport nd from '../images/nd.png';\n\nconst Experience = () => {\n    return (\n        <div className='experience'>\n            <img src={fp} />\n            <div className='company-name'>DoinGud</div>\n            <div className='pos-dat'>\n                <div className='position'>Engineering Lead</div>\n                <p className='dates'>05/2021 – actual</p>\n            </div>\n            <p className='description'>Coordinating communications between teams and processes to help sync development among engineers, product managers, and designers.\n                Owning development knowledge of Org Management tool features.\n            </p>\n            <div className='pos-dat'>\n                <div className='position'>Frontend Engineer</div>\n                <p className='dates'>01/2021 – actual</p>\n            </div>\n            <p className='description'>Collaborated with the engineering team to redesign the profile page for a more user-friendly experience.\n                An analyzed and updated database of the Fight Pandemics to improve resource search.\n             </p> \n\n             <img src={nd} />\n            <div className='company-name'> ND CHANNEL</div>\n            <p className='location'>New York City Metropolitan Area</p>\n            <div className='pos-dat'>\n                <div className='position'>Office Manager</div>\n                <p className='dates'>04/2019 – 03/2020</p>\n            </div>\n            <p className='description'>Created and implemented a prioritization and order status management system which helped improve the order status tracking and made customer communications smoother resulting in less mistakes.\n            Adapted customer service policy to make sure every customer was taken care of in an unconditional standard system, which in turn helped create an impeccable company reputation.\n               </p>  \n\n               <img src={ff} />\n            <div className='company-name'>Fabryka Formy S.A.</div>\n            <p className='location'>Bytom, Śląskie, Poland</p>\n            <div className='pos-dat'>\n                <div className='position'>General Manager</div>\n                <p className='dates'>03/2016 – 11/2017</p>\n            </div>\n            <p className='description'>Accomplished department objectives by creating a timetable for all necessary documentation, which helped improve communication between organization and accounting stuff. Implemented “Name” policy towards customers to ameliorate friendly atmosphere which helped maintain membership roster despite the high prices.\n            </p>  \n    </div>\n    );\n}\n\nexport default Experience;\n","/Users/aleksandra/Flatiron/projects/portfolio/aleksandra/src/components/Projects.js",[],"/Users/aleksandra/Flatiron/projects/portfolio/aleksandra/src/components/Footer.js",[],"/Users/aleksandra/Flatiron/projects/portfolio/aleksandra/src/components/Home.js",[],{"ruleId":"46","replacedBy":"47"},{"ruleId":"48","replacedBy":"49"},{"ruleId":"50","severity":1,"message":"51","line":5,"column":8,"nodeType":"52","messageId":"53","endLine":5,"endColumn":18},{"ruleId":"50","severity":1,"message":"54","line":6,"column":8,"nodeType":"52","messageId":"53","endLine":6,"endColumn":16},{"ruleId":"50","severity":1,"message":"55","line":7,"column":8,"nodeType":"52","messageId":"53","endLine":7,"endColumn":14},{"ruleId":"50","severity":1,"message":"56","line":10,"column":10,"nodeType":"52","messageId":"53","endLine":10,"endColumn":18},{"ruleId":"50","severity":1,"message":"57","line":10,"column":20,"nodeType":"52","messageId":"53","endLine":10,"endColumn":31},{"ruleId":"58","severity":1,"message":"59","line":9,"column":13,"nodeType":"60","endLine":9,"endColumn":29},{"ruleId":"58","severity":1,"message":"59","line":26,"column":14,"nodeType":"60","endLine":26,"endColumn":30},{"ruleId":"58","severity":1,"message":"59","line":37,"column":16,"nodeType":"60","endLine":37,"endColumn":32},"no-native-reassign",["61"],"no-negated-in-lhs",["62"],"no-unused-vars","'Experience' is defined but never used.","Identifier","unusedVar","'Projects' is defined but never used.","'Footer' is defined but never used.","'position' is assigned a value but never used.","'setPosition' is assigned a value but never used.","jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","JSXOpeningElement","no-global-assign","no-unsafe-negation"]